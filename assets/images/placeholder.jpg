<svg xmlns="http://www.w3.org/2000/svg" width="800" height="600" viewBox="0 0 800 600">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#002776;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#009C3B;stop-opacity:1" />
    </linearGradient>
  </defs>
  <rect width="800" height="600" fill="url(#bg)"/>
  <text x="400" y="270" font-family="Arial,sans-serif" font-size="80" text-anchor="middle" fill="rgba(255,255,255,0.15)">🌊</text>
  <text x="400" y="340" font-family="Arial,sans-serif" font-size="22" font-weight="bold" text-anchor="middle" fill="rgba(255,255,255,0.5)" letter-spacing="4">TEMA AVENTURAS</text>
  <text x="400" y="375" font-family="Arial,sans-serif" font-size="13" text-anchor="middle" fill="rgba(255,255,255,0.3)">Adicione uma imagem destacada</text>
</svg>
